# Copy this file to secrets.toml and fill in values.
# secrets.toml should NEVER be committed to git.

# Password to access the app. Anyone hitting the URL has to enter this.
app_password = "change-me-to-something-strong"

# Optional: pre-configured API keys.
# If set, the user doesn't have to enter one in the sidebar.
# Leave blank/commented to require BYO key in the UI.
# openai_api_key = "sk-..."
# anthropic_api_key = "sk-ant-..."
# google_api_key = "AIza..."
